generator client {
  provider      = "prisma-client-js"
  engineType    = "binary"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider     = "sqlite"
  url          = env("ORDERS_DATABASE_URL")
  relationMode = "prisma"
}

enum OrderStatus {
  REVIEW
  PLANNING
  IN_PROGRESS
  IN_DELIVERY
  DELIVERED
  CANCELLED
}

enum LabWorkStatus {
  TO_SCAN
  TO_EXECUTION
  APPROVAL
  PRODUCTION
  ASSEMBLY
  PROCESSING
  MANUAL
  TO_REVIEW
  TO_ADMINS
}

enum DemoKanbanColumn {
  NEW
  IN_PROGRESS
  DONE
}

enum KaitenTrackLane {
  ORTHOPEDICS
  ORTHODONTICS
  TEST
}

enum OrderCorrectionTrack {
  ORTHOPEDICS
  ORTHODONTICS
  REWORK
}

enum OrderChatCorrectionSource {
  KAITEN
  DEMO_KANBAN
}

enum OrderRevisionKind {
  CREATE
  SAVE
  RESTORE
}

enum OrderPriceListKind {
  MAIN
  CUSTOM
}

enum ConstructionCategory {
  FIXED
  CONNECTING
  BRIDGE
  MISSING_TEETH
  ARCH
  PRICE_LIST
}

enum JawArch {
  UPPER
  LOWER
  BOTH
}

model Order {
  id                             String               @id @default(cuid())
  tenantId                       String
  orderNumber                    String
  clinicId                       String?
  doctorId                       String
  patientName                    String?
  appointmentDate                DateTime?
  dueDate                        DateTime?
  dueToAdminsAt                  DateTime?
  workReceivedAt                 DateTime?
  status                         OrderStatus          @default(REVIEW)
  notes                          String?
  clientOrderText                String?
  isUrgent                       Boolean              @default(false)
  urgentCoefficient              Float?
  labWorkStatus                  LabWorkStatus        @default(TO_EXECUTION)
  legalEntity                    String?
  payment                        String?
  excludeFromReconciliation      Boolean              @default(false)
  excludeFromReconciliationUntil DateTime?
  shade                          String?
  hasScans                       Boolean              @default(false)
  hasCt                          Boolean              @default(false)
  hasMri                         Boolean              @default(false)
  hasPhoto                       Boolean              @default(false)
  additionalSourceNotes          String?
  quickOrder                     Json?
  prosthetics                    Json?
  kaitenDecideLater              Boolean              @default(false)
  kaitenCardTypeId               String?
  kaitenTrackLane                KaitenTrackLane?
  kaitenAdminDueHasTime          Boolean              @default(true)
  kaitenCardTitleLabel           String?
  kaitenCardId                   Int?
  demoKanbanColumn               DemoKanbanColumn?
  kaitenSyncError                String?
  kaitenSyncedAt                 DateTime?
  kaitenColumnTitle              String?
  kaitenCardSortOrder            Float?
  kaitenCardTitleMirror          String?
  kaitenCardDescriptionMirror    String?
  kaitenBlocked                  Boolean              @default(false)
  kaitenBlockReason              String?
  invoiceIssued                  Boolean              @default(false)
  invoiceNumber                  String?
  invoicePaperDocs               Boolean              @default(false)
  invoiceSentToEdo               Boolean              @default(false)
  invoiceEdoSigned               Boolean              @default(false)
  invoicePrinted                 Boolean              @default(false)
  narjadPrinted                  Boolean              @default(false)
  adminShippedOtpr               Boolean              @default(false)
  shippedDescription             String?
  invoiceParsedLines             Json?
  invoiceParsedTotalRub          Int?
  invoiceParsedSummaryText       String?
  invoicePaymentNotes            String?
  orderPriceListKind             OrderPriceListKind?
  orderPriceListNote             String?
  compositionDiscountPercent     Float                @default(0)
  continuesFromOrderId           String?
  prostheticsOrdered             Boolean              @default(false)
  correctionTrack                OrderCorrectionTrack?
  registeredByLabel              String?
  courierId                      String?
  courierPickupId                String?
  courierDeliveryId              String?
  invoiceAttachmentId            String?              @unique
  archivedAt                     DateTime?
  createdAt                      DateTime             @default(now())
  updatedAt                      DateTime             @updatedAt
  constructions                  OrderConstruction[]
  attachments                    OrderAttachment[]
  revisions                      OrderRevision[]
  listCustomTags                 OrderCustomTag[]
  chatCorrections                OrderChatCorrection[]
  prostheticsRequests            OrderProstheticsRequest[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([clinicId])
  @@index([status])
  @@index([labWorkStatus])
  @@index([createdAt])
  @@index([courierId])
  @@index([courierPickupId])
  @@index([courierDeliveryId])
  @@index([continuesFromOrderId])
  @@index([archivedAt, createdAt])
}

model OrderAttachment {
  id                 String   @id @default(cuid())
  orderId            String
  order              Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fileName           String
  mimeType           String
  size               Int
  data               Bytes
  diskRelPath        String?
  uploadedToKaitenAt DateTime?
  kaitenFileId       Int?
  createdAt          DateTime @default(now())

  @@index([orderId])
}

model OrderConstruction {
  id                  String               @id @default(cuid())
  orderId             String
  order               Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  category            ConstructionCategory
  constructionTypeId  String?
  priceListItemId     String?
  materialId          String?
  shade               String?
  teethFdi            Json?
  bridgeFromFdi       String?
  bridgeToFdi         String?
  arch                JawArch?
  quantity            Int                  @default(1)
  unitPrice           Float?
  lineDiscountPercent Float                @default(0)
  sortOrder           Int                  @default(0)
  createdAt           DateTime             @default(now())

  @@index([orderId])
}

model OrderRevision {
  id          String            @id @default(cuid())
  orderId     String
  order       Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now())
  actorLabel  String
  actorUserId String?
  summary     String
  kind        OrderRevisionKind @default(SAVE)
  snapshot    Json

  @@index([orderId, createdAt])
  @@index([actorUserId, createdAt])
}

model OrderCustomTag {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  label   String

  @@unique([orderId, label])
  @@index([label])
  @@index([orderId])
}

model OrderChatCorrection {
  id               String                    @id @default(cuid())
  orderId          String
  order            Order                     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  source           OrderChatCorrectionSource
  text             String
  kaitenCommentId  Int?
  createdAt        DateTime                  @default(now())
  resolvedAt       DateTime?
  resolvedByUserId String?
  rejectedAt       DateTime?
  rejectedByUserId String?

  @@unique([orderId, kaitenCommentId])
  @@index([orderId, resolvedAt])
  @@index([orderId, rejectedAt])
  @@index([orderId, createdAt])
}

model OrderProstheticsRequest {
  id               String                    @id @default(cuid())
  orderId          String
  order            Order                     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  source           OrderChatCorrectionSource
  text             String
  kaitenCommentId  Int?
  createdAt        DateTime                  @default(now())
  resolvedAt       DateTime?
  resolvedByUserId String?
  rejectedAt       DateTime?
  rejectedByUserId String?

  @@unique([orderId, kaitenCommentId])
  @@index([orderId, resolvedAt])
  @@index([orderId, rejectedAt])
}

model OrderNumberSettings {
  id                String   @id
  postingYearMonth  String
  nextSequenceFloor Int?
  updatedAt         DateTime @updatedAt
}


