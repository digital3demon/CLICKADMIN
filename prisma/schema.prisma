// На Windows library-движок (.dll.node) часто даёт EPERM при generate; binary — отдельный .exe.
// binaryTargets: при сборке на Windows в архив попадают и движки для Linux (NetAngels / Debian OpenSSL 3).
generator client {
  provider      = "prisma-client-js"
  engineType    = "binary"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// ИП / ООО — документооборот с клиникой (колонка «Работаем от Юр.лица»)
enum BillingLegalForm {
  IP
  OOO
}

/// Как часто сверяемся с клиникой (при worksWithReconciliation)
enum ReconciliationFrequency {
  MONTHLY_1
  MONTHLY_2
}

/// Автоснимок сверки (период по рабочим дням МСК, файл xlsx в БД).
enum ReconciliationSnapshotSlot {
  MONTHLY_FULL
  FIRST_HALF
  SECOND_HALF
}

/// Событие по контрагенту в общей ленте «История изменений»
enum ContractorRevisionKind {
  CREATE
  UPDATE
  DELETE
  RESTORE
}

/// Тариф подписки (SaaS); смотри lib/plan-entitlements.ts
enum SubscriptionPlan {
  BASIC
  OPTIMAL
  ULTRA
}

/// Организация (тенант): поддомен `slug`, прайс-модули, опция канбана
model Tenant {
  id                    String           @id @default(cuid())
  /// Поддомен: `xxx` в `xxx.click-lab.online`
  slug                  String           @unique
  name                  String?
  plan                  SubscriptionPlan @default(BASIC)
  /// Опция «Канбан» (доска в CRM), отдельно от тарифа
  addonKanban           Boolean          @default(false)
  /// null — без срока / вечная лицензия
  subscriptionValidTo   DateTime?
  createdAt             DateTime         @default(now())
  users                 User[]
  orders                Order[]
  clinics               Clinic[]
  doctors               Doctor[]
  couriers              Courier[]
  kaitenCardTypes       KaitenCardType[]
  orderNumberSettings   OrderNumberSettings?
  subscriptionInvoices  SubscriptionInvoice[]
  /// Переопределения доступа к модулям; если записи нет — см. `lib/role-module-defaults`
  roleModuleAccess      RoleModuleAccess[]
}

/// Счёт на подписку (B2B выставленный вручную или оплата эквайрингом)
enum SubscriptionInvoiceStatus {
  DRAFT
  PENDING
  PAID
  CANCELLED
}

enum SubscriptionPaymentProvider {
  MANUAL
  YOOKASSA
}

model SubscriptionInvoice {
  id                 String                        @id @default(cuid())
  tenantId           String
  tenant             Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  amountMinor        Int
  currency           String                        @default("RUB")
  status             SubscriptionInvoiceStatus     @default(PENDING)
  provider           SubscriptionPaymentProvider  @default(MANUAL)
  /// id платежа у провайдера (YooKassa: payment_id)
  providerExternalId String?                       @unique
  /// Текст для печатного счёта / комментарий
  title              String?
  createdAt          DateTime                      @default(now())
  paidAt             DateTime?

  @@index([tenantId, createdAt])
  @@index([status])
}

/// Клиника-заказчик
model Clinic {
  id                           String                         @id @default(cuid())
  tenantId                     String
  tenant                       Tenant                         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Краткое / рабочее название в CRM
  name                         String
  address                      String?
  /// false — не ведём активную работу (колонка «Не активна» в Excel и т.п.)
  isActive                     Boolean                        @default(true)
  /// Контакты, заметки, то что не разложено по полям (не дублируем весь Excel)
  notes                        String?
  /// Полное юридическое наименование
  legalFullName                String?
  /// Юридический адрес
  legalAddress                 String?
  inn                          String?
  kpp                          String?
  ogrn                         String?
  bankName                     String?
  bik                          String?
  /// Расчётный счёт
  settlementAccount            String?
  /// Корреспондентский счёт
  correspondentAccount         String?
  phone                        String?
  email                        String?
  /// Руководитель (ФИО, должность — как заведено)
  ceoName                      String?
  /// Работают по сверке (колонка «Сверка» в реестре)
  worksWithReconciliation      Boolean                        @default(false)
  /// Периодичность сверки: 1 или 2 раза в месяц (если не указано — только флаг «по сверке»)
  reconciliationFrequency      ReconciliationFrequency?
  /// Договор подписан (колонка «Подписан» у «Договор»)
  contractSigned               Boolean                        @default(false)
  /// Номер договора (если подписан)
  contractNumber               String?
  /// Работа по ЭДО
  worksWithEdo                 Boolean                        @default(false)
  /// От какого юрлица ведётся работа: ИП или ООО
  billingLegalForm             BillingLegalForm?
  /// Если задано — клиника создана как «юрлицо врача-ИП» (дублирование в справочнике клиник)
  sourceDoctorId               String?                        @unique
  sourceDoctor                 Doctor?                        @relation("ClinicAsDoctorIp", fields: [sourceDoctorId], references: [id], onDelete: SetNull)
  /// Прайс по умолчанию для нарядов с этой клиникой (врач в карточке может переопределить)
  orderPriceListKind           OrderPriceListKind?
  doctorLinks                  DoctorOnClinic[]
  /// Пары врач–клиника, отвязанные вручную (восстановление по нарядам отключено)
  doctorClinicLinkSuppressions DoctorClinicLinkSuppression[]
  /// Индивидуальные цены клиники по позициям активного прайса.
  priceOverrides               ClinicPriceOverride[]
  orders                       Order[]
  contractorRevisions          ContractorRevision[]
  reconciliationSnapshots      ClinicReconciliationSnapshot[]
  costingProfiles              CostingClientProfile[]
  createdAt                    DateTime                       @default(now())
  /// Мягкое удаление: скрыта в списках, восстановление из «Истории»
  deletedAt                    DateTime?

  @@index([tenantId])
}

/// Автоматически сформированная сверка (конец периода, МСК 20:00, cron).
model ClinicReconciliationSnapshot {
  id               String                     @id @default(cuid())
  clinicId         String
  clinic           Clinic                     @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  slot             ReconciliationSnapshotSlot
  /// Границы периода для выгрузки (как в UI «Финансы»: YYYY-MM-DD, календарные дни UTC).
  periodFromStr    String
  periodToStr      String
  /// Подпись периода для уведомления, напр. «01.04–15.04.2026»
  periodLabelRu    String
  legalEntityLabel String
  xlsxBytes        Bytes
  createdAt        DateTime                   @default(now())
  dismissedAt      DateTime?

  @@unique([clinicId, slot, periodFromStr, periodToStr])
  @@index([clinicId, createdAt])
  @@index([dismissedAt])
}

/// Связь врач ↔ клиника (M:N). Один врач может работать в нескольких клиниках.
model DoctorOnClinic {
  doctorId String
  clinicId String
  doctor   Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@id([doctorId, clinicId])
  @@index([clinicId])
  @@index([doctorId])
}

/// Связь врач–клиника скрыта в CRM; repair по нарядам не создаёт DoctorOnClinic, пока запись есть.
/// Снимается при явном сохранении наряда с этой парой (ensureDoctorClinicLink).
model DoctorClinicLinkSuppression {
  doctorId  String
  clinicId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([doctorId, clinicId])
  @@index([clinicId])
}

model Doctor {
  id                     String              @id @default(cuid())
  tenantId               String
  tenant                 Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Отображаемое ФИО (собирается из частей при импорте из реестра)
  fullName               String
  /// Фамилия без инициалов (из столбца «Фамилия врача»)
  lastName               String?
  firstName              String?
  patronymic             String?
  /// Прежняя фамилия
  formerLastName         String?
  specialty              String?
  city                   String?
  /// Личный e-mail
  email                  String?
  /// Почта клиники, с которой присылают работы
  clinicWorkEmail        String?
  /// Телефон
  phone                  String?
  /// Предпочтительный способ связи (свободный текст: Telegram, WhatsApp и т.д.)
  preferredContact       String?
  /// Ник в Telegram (без @)
  telegramUsername       String?
  birthday               DateTime?
  /// Особенности / заметки
  particulars            String?
  /// Принимает наряды как частное лицо (без привязки к клинике в заказе)
  acceptsPrivatePractice Boolean             @default(false)
  /// Ведёт деятельность как ИП: в справочнике клиник появляется зеркальная запись с реквизитами (как у клиники)
  isIpEntrepreneur       Boolean             @default(false)
  /// Прайс в нарядах: если задан — перекрывает настройку клиники; при частной практике — единственный источник
  orderPriceListKind     OrderPriceListKind?

  /// Клиника-зеркало для ИП (один врач — одна запись); создаётся при включённой галочке
  ipClinicAsSource Clinic?      @relation("ClinicAsDoctorIp")
  clinicLinks                  DoctorOnClinic[]
  doctorClinicLinkSuppressions DoctorClinicLinkSuppression[]
  orders                       Order[]
  contractorRevisions          ContractorRevision[]
  createdAt                    DateTime                      @default(now())
  /// Мягкое удаление: скрыта в списках, восстановление из «Истории»
  deletedAt                    DateTime?

  @@index([tenantId])
}

/// Журнал изменений клиник и врачей (контрагенты)
model ContractorRevision {
  id          String                 @id @default(cuid())
  createdAt   DateTime               @default(now())
  actorLabel  String
  /// Учётная запись автора (если null — старые записи до введения поля)
  actorUserId String?
  actorUser   User?                  @relation("ContractorRevisionActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  kind        ContractorRevisionKind @default(UPDATE)
  clinicId    String?
  clinic      Clinic?                @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  doctorId    String?
  doctor      Doctor?                @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  summary     String
  /// Структура для UI: до/после полей, снимок до удаления (см. ContractorRevisionDetailsV1)
  details     Json?

  @@index([createdAt])
  @@index([actorUserId, createdAt])
}

enum OrderStatus {
  REVIEW
  PLANNING
  IN_PROGRESS
  IN_DELIVERY
  DELIVERED
  CANCELLED
}

/// Этап работы в лаборатории (колонки Kaiten; «Отправлено» — отдельно `adminShippedOtpr`)
enum LabWorkStatus {
  TO_SCAN
  TO_EXECUTION
  APPROVAL
  PRODUCTION
  ASSEMBLY
  PROCESSING
  MANUAL
  TO_REVIEW
  TO_ADMINS
}

/// Внутренний канбан (демо и будущая замена Kaiten в основной CRM)
enum DemoKanbanColumn {
  NEW
  IN_PROGRESS
  DONE
}

/// Пространство / целевая доска в Кайтен
enum KaitenTrackLane {
  ORTHOPEDICS
  ORTHODONTICS
  /// Пространство «ТЕСТ» (доска задаётся KAITEN_TEST_* или совпадает с ортопедией)
  TEST
}

/// Направление коррекции (отдельно от дорожки Kaiten)
enum OrderCorrectionTrack {
  ORTHOPEDICS
  ORTHODONTICS
  REWORK
}

/// Откуда занесена корректировка по префиксу «!!!» в чате
enum OrderChatCorrectionSource {
  KAITEN
  DEMO_KANBAN
}

/// Крупные модули CRM: вкл/выкл по роли (настраивает владелец в «Пользователи»)
enum AppModule {
  /// Заказы, наряды, новый заказ
  ORDERS
  KANBAN
  /// История изменений по нарядам
  ORDER_HISTORY
  /// Финансовая аналитика
  ANALYTICS
  /// Отгрузки (даты, вкладки)
  SHIPMENTS
  /// Склад: раздел + API инвентаря
  WAREHOUSE
  /// Клиенты, врачи, клиники
  CLIENTS
  /// «Обратить внимание» / напоминания
  ATTENTION
  /// Хаб «Конфигурация» (/directory)
  DIRECTORY
  /// Плитки: прайс, склад, канбан-доски, кайтен, курьеры (отдельно)
  CONFIG_PRICING
  CONFIG_WAREHOUSE
  CONFIG_KANBAN_BOARDS
  CONFIG_KAITEN
  CONFIG_COURIERS
  /// Просчёт работ (Ультра; по умолчанию только владелец)
  CONFIG_COSTING
  /// Список и приглашения (по умолчанию только владелец)
  CONFIG_USERS
}

/// Роль пользователя CRM (права будут расширяться)
enum UserRole {
  ADMINISTRATOR
  SENIOR_ADMINISTRATOR
  ACCOUNTANT
  FINANCIAL_MANAGER
  /// Только канбан-доска (без заказов, справочников и пр.)
  USER
  OWNER
}

/// Пользователь: владелец и сотрудники — вход по паролю; до активации хранится inviteCodeHash
model User {
  id                        String    @id @default(cuid())
  tenantId                  String
  tenant                    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email                     String
  displayName               String
  role                      UserRole
  /// Bcrypt-хэш пароля (вход после активации приглашения)
  passwordHash              String?
  /// Bcrypt одноразового кода приглашения; null после установки пароля
  inviteCodeHash            String?
  /// false — вход запрещён (сессия сбрасывается при следующей загрузке)
  isActive                  Boolean   @default(true)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  lastLoginAt               DateTime?
  /// Числовой id Telegram (строка), уникален если задан — привязка для уведомлений в боте (вход в CRM — только почта/пароль)
  telegramId                String?   @unique
  /// @username из Telegram (без @), для отображения
  telegramUsername          String?
  /// Вкл/выкл уведомлений в Telegram по типам событий канбана/Kaiten (ключ → boolean)
  telegramKanbanNotifyPrefs Json?
  /// Нормализованный российский номер (11 цифр с 7), уникален если задан — приглашение по телефону и вход в Telegram
  phone                     String?   @unique
  /// id из `PROFILE_AVATAR_PRESETS` (эмодзи-животные) или null
  avatarPresetId            String?
  /// MIME загруженного фото (image/jpeg, image/png, image/webp); null — своего файла нет
  avatarCustomMime          String?
  avatarCustomUploadedAt    DateTime?
  /// Кастомное фото (BYTEA). Раньше файл был только на диске `data/user-avatars` — для таких строк может быть null до повторной загрузки.
  avatarCustomData          Bytes?
  /// Ник для @упоминаний (латиница, цифры, _; хранится без @), позже — уведомления в Telegram
  mentionHandle             String?   @unique
  /// Сколько нарядов на странице списка /orders (1–200); null — значение по умолчанию в приложении
  ordersListPageSize        Int?

  telegramLinkTokens TelegramLinkToken[]

  orderRevisionsAsActor            OrderRevision[]           @relation("OrderRevisionActor")
  contractorRevisionsAsActor       ContractorRevision[]      @relation("ContractorRevisionActor")
  orderChatCorrectionsResolved     OrderChatCorrection[]     @relation("OrderChatCorrectionResolvedBy")
  orderChatCorrectionsRejected     OrderChatCorrection[]     @relation("OrderChatCorrectionRejectedBy")
  orderProstheticsRequestsResolved OrderProstheticsRequest[] @relation("OrderProstheticsRequestResolvedBy")
  orderProstheticsRequestsRejected OrderProstheticsRequest[] @relation("OrderProstheticsRequestRejectedBy")

  @@unique([tenantId, email])
  @@index([role])
  @@index([isActive])
  @@index([tenantId])
}

/// Доступ к модулю для роли в тенанте. Нет записи = значение по умолчанию из `lib/role-module-defaults`.
model RoleModuleAccess {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role      UserRole
  module    AppModule
  allowed   Boolean
  updatedAt DateTime @updatedAt

  @@unique([tenantId, role, module])
  @@index([tenantId, role])
}

/// Ожидание email в диалоге с ботом при привязке (после /start).
model TelegramBotLinkPending {
  telegramUserId String   @id
  tenantSlug     String
  updatedAt      DateTime @updatedAt
}

/// Одноразовая ссылка из бота для подтверждения привязки Telegram к User.
model TelegramLinkToken {
  id               String    @id @default(cuid())
  token            String    @unique
  userId           String
  tenantId         String
  telegramUserId   String
  telegramUsername String?
  expiresAt        DateTime
  consumedAt       DateTime?
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([telegramUserId])
}

/// Курьерская служба / курьер (справочник в конфигурации)
model Courier {
  id                  String   @id @default(cuid())
  tenantId            String
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name                String
  sortOrder           Int      @default(0)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  /// Устаревшая связь (один курьер на наряд); дублирует привоз, если задан только он
  ordersLegacy        Order[]  @relation("OrderCourierLegacy")
  ordersAsPickupFor   Order[]  @relation("OrderCourierPickup")
  ordersAsDeliveryFor Order[]  @relation("OrderCourierDelivery")

  @@index([tenantId, isActive, sortOrder])
  @@index([name])
}

/// Запись в журнале версий наряда (для истории и отката).
enum OrderRevisionKind {
  CREATE
  SAVE
  RESTORE
}

model OrderRevision {
  id          String            @id @default(cuid())
  orderId     String
  order       Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now())
  actorLabel  String
  /// Учётная запись автора (если null — старые записи до введения поля)
  actorUserId String?
  actorUser   User?             @relation("OrderRevisionActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  summary     String
  kind        OrderRevisionKind @default(SAVE)
  /// Снимок наряда + позиций (JSON), см. OrderSnapshotV1 в коде
  snapshot    Json

  @@index([orderId, createdAt])
  @@index([actorUserId, createdAt])
}

/// Один ряд на тенант: месяц нумерации нарядов (YYMM). `id` = `Tenant.id`.
model OrderNumberSettings {
  id                String   @id
  tenant            Tenant  @relation(fields: [id], references: [id], onDelete: Cascade)
  /// Префикс наряда: 2 цифры года + 2 цифры месяца, напр. «2601» → номера 2601-001, 2601-002…
  postingYearMonth  String
  /// Если задано: следующий номер ≥ этому суффиксу NNN (при том же YYMM), пока не обгонит max в БД.
  nextSequenceFloor Int?
  updatedAt         DateTime @updatedAt
}

/// Основной или индивидуальный прайс по наряду (колонка «ПРАЙС» в Excel)
enum OrderPriceListKind {
  MAIN
  CUSTOM
}

/// Тип карточки в Kaiten (добавление в конфигурации; externalTypeId — type_id в API Kaiten)
model KaitenCardType {
  id             String  @id @default(cuid())
  tenantId       String
  tenant         Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String
  /// Числовой id типа в Kaiten (POST cards type_id)
  externalTypeId Int
  sortOrder      Int     @default(0)
  isActive       Boolean @default(true)
  orders         Order[]

  @@index([tenantId, isActive, sortOrder])
  @@index([name])
}

model Order {
  id                             String                    @id @default(cuid())
  tenantId                       String
  tenant                         Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Номер наряда: YYMM-NNN (напр. 2601-001)
  orderNumber                    String
  /// null — наряд от врача как от частного лица
  clinicId                       String?
  clinic                         Clinic?                   @relation(fields: [clinicId], references: [id])
  doctorId                       String
  doctor                         Doctor                    @relation(fields: [doctorId], references: [id])
  patientName                    String?
  /// Дата приёма пациента (отгрузки; при создании/редактировании совпадает с dueToAdminsAt)
  appointmentDate                DateTime?
  /// Срок лабораторный (шапка Kaiten / канбан / печать)
  dueDate                        DateTime?
  /// Дата приёма пациента (в CRM и отгрузках; синхронно с appointmentDate при сохранении)
  dueToAdminsAt                  DateTime?
  /// Когда работа поступила в лабораторию; null — считать моментом занесения наряда (createdAt)
  workReceivedAt                 DateTime?
  status                         OrderStatus               @default(REVIEW)
  notes                          String?
  /// Текст заказа от клиента (копируют из переписки); в описание карточки Kaiten вместе с комментарием
  clientOrderText                String?
  /// Отмечена срочность (в т.ч. без коэффициента)
  isUrgent                       Boolean                   @default(false)
  /// Коэффициент срочности; null если срочно без множителя или не срочно
  urgentCoefficient              Float?
  /// Текущий этап работы (индикатор в шапке)
  labWorkStatus                  LabWorkStatus             @default(TO_EXECUTION)
  legalEntity                    String?
  payment                        String?
  /// Не включать позиции наряда в выгрузку сверки за период (см. excludeFromReconciliationUntil)
  excludeFromReconciliation      Boolean                   @default(false)
  /// Конец периода (UTC), до которого наряд скрыт из сверки; null — скрыт во всех периодах, пока не снят флаг
  excludeFromReconciliationUntil DateTime?
  shade                          String?
  hasScans                       Boolean                   @default(false)
  hasCt                          Boolean                   @default(false)
  hasMri                         Boolean                   @default(false)
  hasPhoto                       Boolean                   @default(false)
  /// Исходные данные: что ещё есть к работе (свободный текст)
  additionalSourceNotes          String?
  /// Снимок «Быстрый наряд» и продолжение работы
  quickOrder                     Json?
  /// Протетика: клиент / наше (склад), см. OrderProstheticsV1
  prosthetics                    Json?
  /// Кайтен: если true — тип и пространство не заданы
  kaitenDecideLater              Boolean                   @default(false)
  kaitenCardTypeId               String?
  kaitenCardType                 KaitenCardType?           @relation(fields: [kaitenCardTypeId], references: [id], onDelete: SetNull)
  kaitenTrackLane                KaitenTrackLane?
  /// false — в Kaiten и в шапке только дата сдачи админам, без времени («в течение дня»)
  kaitenAdminDueHasTime          Boolean                   @default(true)
  /// Текст между врачом и датой в шапке; пусто — подставляется название типа карточки
  kaitenCardTitleLabel           String?
  /// ID карточки в Kaiten после успешного POST /cards
  kaitenCardId                   Int?
  /// Демо / внутренний канбан: колонка «Новые» / «В работе» / «Готово»
  demoKanbanColumn               DemoKanbanColumn?
  kaitenSyncError                String?
  kaitenSyncedAt                 DateTime?
  /// Подпись колонки доски Kaiten (обновляется при открытии вкладки «Кайтен» / после синхронизации)
  kaitenColumnTitle              String?
  /// Порядок карточки в колонке Kaiten (`sort_order` в API); для зеркала канбана по вертикали
  kaitenCardSortOrder            Float?
  /// Заголовок карточки Kaiten (кэш для зеркала канбана; обновляется GET/PATCH Kaiten)
  kaitenCardTitleMirror          String?
  /// Описание карточки Kaiten (кэш для зеркала канбана)
  kaitenCardDescriptionMirror    String?
  /// Карточка Kaiten в состоянии «заблокирована» (синхронизация из Kaiten и после действий в CRM)
  kaitenBlocked                  Boolean                   @default(false)
  /// Текст причины блокировки из Kaiten (красная полоса в Kaiten / подсказка в списке CRM)
  kaitenBlockReason              String?
  /// Счёт по наряду выставлен клиенту
  invoiceIssued                  Boolean                   @default(false)
  /// Номер выставленного счёта (ручной ввод)
  invoiceNumber                  String?
  /// Бумажные документы переданы / учтены
  invoicePaperDocs               Boolean                   @default(false)
  /// Счёт отправлен в ЭДО
  invoiceSentToEdo               Boolean                   @default(false)
  /// Подписано в ЭДО
  invoiceEdoSigned               Boolean                   @default(false)
  /// Счёт распечатан (отмечено в документообороте)
  invoicePrinted                 Boolean                   @default(false)
  /// Админ распечатал наряд
  narjadPrinted                  Boolean                   @default(false)
  /// Отправлено: работа отгружена / отправлена клиенту (внутренний флаг админов)
  adminShippedOtpr               Boolean                   @default(false)
  /// Что фактически отгружено (текст при отметке «Работа отправлена»)
  shippedDescription             String?
  /// Разбор счёта PDF: строки позиций (JSON-массив `{ name, qty, code? }[]`)
  invoiceParsedLines             Json?
  /// Сумма «к оплате» из счёта, целые рубли (если распознана)
  invoiceParsedTotalRub          Int?
  /// Текст блока «выставлено» / ручная правка поверх авторазбора
  invoiceParsedSummaryText       String?
  /// Комментарии к счёту и оплатам
  invoicePaymentNotes            String?
  /// Прайс: основной каталог или индивидуальный
  orderPriceListKind             OrderPriceListKind?
  /// Подпись прайса (файл, договор, произвольный текст)
  orderPriceListNote             String?
  /// Общая скидка на весь «Состав заказа», % (0–100; применяется к сумме строк после скидок по позициям)
  compositionDiscountPercent     Float                    @default(0)
  /// Логическое продолжение другого наряда (после отгрузки / новый этап)
  continuesFromOrderId           String?
  continuesFromOrder             Order?                    @relation("OrderContinuation", fields: [continuesFromOrderId], references: [id], onDelete: SetNull)
  continuationOrders             Order[]                   @relation("OrderContinuation")
  /// Протетика заказана (учёт в шапке наряда)
  prostheticsOrdered             Boolean                   @default(false)
  /// Коррекция: направление (ортопедия / ортодонтия); null — не коррекция
  correctionTrack                OrderCorrectionTrack?
  /// Для переделки: true — за счет заказчика, false — внутренняя переделка
  reworkAtCustomerExpense        Boolean                   @default(false)
  /// Кто занёс наряд в CRM (подпись с момента создания)
  registeredByLabel              String?
  /// Устаревшее поле: синхронизируется с привозом при сохранении из CRM
  courierId                      String?
  courier                        Courier?                  @relation("OrderCourierLegacy", fields: [courierId], references: [id], onDelete: SetNull)
  /// Курьер привоза (к лаборатории)
  courierPickupId                String?
  courierPickup                  Courier?                  @relation("OrderCourierPickup", fields: [courierPickupId], references: [id], onDelete: SetNull)
  /// Курьер отвоза (от лаборатории к клиенту) — может отличаться от привоза
  courierDeliveryId              String?
  courierDelivery                Courier?                  @relation("OrderCourierDelivery", fields: [courierDeliveryId], references: [id], onDelete: SetNull)
  /// Загруженный файл счёта (вкладка счёта / зона загрузки); скачивание счёта из CRM
  invoiceAttachmentId            String?                   @unique
  invoiceAttachment              OrderAttachment?          @relation("InvoiceAttachmentForOrder", fields: [invoiceAttachmentId], references: [id], onDelete: SetNull)
  constructions                  OrderConstruction[]
  attachments                    OrderAttachment[]
  revisions                      OrderRevision[]
  stockMovements                 StockMovement[]
  /// Произвольные теги для фильтра в списке заказов (клик по «Отметкам»)
  listCustomTags                 OrderCustomTag[]
  /// Корректировки из чата (сообщения с префиксом «!!!»)
  chatCorrections                OrderChatCorrection[]
  /// Заявки по протетике из чата (префикс «???»)
  prostheticsRequests            OrderProstheticsRequest[]
  /// Мягкое архивирование («удаление»): наряд скрыт из списков и канбана; номер YYMM-NNN снимается (плейхолдер `ARCH:id`), чтобы его можно было выдать другому наряду.
  archivedAt                     DateTime?
  createdAt                      DateTime                  @default(now())
  updatedAt                      DateTime                  @updatedAt

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([clinicId])
  @@index([status])
  @@index([labWorkStatus])
  @@index([kaitenCardTypeId])
  @@index([createdAt])
  @@index([courierId])
  @@index([courierPickupId])
  @@index([courierDeliveryId])
  @@index([continuesFromOrderId])
  @@index([archivedAt, createdAt])
}

/// Корректировка состава: текст из чата Kaiten/канбана с префиксом «!!!»; принятие — галочка админом.
model OrderChatCorrection {
  id               String                    @id @default(cuid())
  orderId          String
  order            Order                     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  source           OrderChatCorrectionSource
  /// Текст без префикса «!!!»
  text             String
  /// id комментария в Kaiten — чтобы подтягивать «!!!» из UI Kaiten без дублей
  kaitenCommentId  Int?
  createdAt        DateTime                  @default(now())
  resolvedAt       DateTime?
  resolvedByUserId String?
  resolvedBy       User?                     @relation("OrderChatCorrectionResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)
  /// Отклонена (красный ✗); в Kaiten уходит «корректировка не принята»
  rejectedAt       DateTime?
  rejectedByUserId String?
  rejectedBy       User?                     @relation("OrderChatCorrectionRejectedBy", fields: [rejectedByUserId], references: [id], onDelete: SetNull)

  @@unique([orderId, kaitenCommentId])
  @@index([orderId, resolvedAt])
  @@index([orderId, rejectedAt])
  @@index([orderId, createdAt])
}

/// Заявка по протетике из чата Kaiten/канбана (префикс «???» в тексте комментария)
model OrderProstheticsRequest {
  id               String                    @id @default(cuid())
  orderId          String
  order            Order                     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  source           OrderChatCorrectionSource
  /// Текст без префикса «???»
  text             String
  kaitenCommentId  Int?
  createdAt        DateTime                  @default(now())
  resolvedAt       DateTime?
  resolvedByUserId String?
  resolvedBy       User?                     @relation("OrderProstheticsRequestResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)
  rejectedAt       DateTime?
  rejectedByUserId String?
  rejectedBy       User?                     @relation("OrderProstheticsRequestRejectedBy", fields: [rejectedByUserId], references: [id], onDelete: SetNull)

  @@unique([orderId, kaitenCommentId])
  @@index([orderId, resolvedAt])
  @@index([orderId, rejectedAt])
}

/// Свободный тег наряда (фильтр «как у этого тега» в списке заказов)
model OrderCustomTag {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  label   String

  @@unique([orderId, label])
  @@index([label])
  @@index([orderId])
}

/// Файлы по заказу (в т.ч. выгрузка в Kaiten)
model OrderAttachment {
  id                      String    @id @default(cuid())
  orderId                 String
  order                   Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  /// Обратная связь: этот файл выбран как счёт для наряда
  linkedAsInvoiceForOrder Order?    @relation("InvoiceAttachmentForOrder")
  fileName                String
  mimeType                String
  size                    Int
  /// Содержимое файла (BYTEA). Новые загрузки — всегда здесь; старые могли быть на диске (`diskRelPath`) с пустым `data`.
  data                    Bytes
  /// Устаревшее: байты только на диске (до перехода на хранение в БД).
  diskRelPath             String?
  uploadedToKaitenAt      DateTime?
  /// id файла в Kaiten после PUT /cards/{id}/files (для удаления в Kaiten при удалении из CRM)
  kaitenFileId            Int?
  createdAt               DateTime  @default(now())

  @@index([orderId])
}

/// Типы работ в конфигурации (коронка, сплинт и т.д.)
model ConstructionType {
  id         String              @id @default(cuid())
  name       String
  code       String?
  /// true — работа на челюсть/дугу без обязательного списка зубов
  isArchWork Boolean             @default(false)
  lines      OrderConstruction[]
}

model Material {
  id    String              @id @default(cuid())
  name  String
  lines OrderConstruction[]
}

/// Вид складской операции (направление задаётся типом, quantity всегда > 0)
enum StockMovementKind {
  /// Приход от поставщика (закупка)
  PURCHASE_RECEIPT
  /// Расход по наряду (продажа / отпуск в работу)
  SALE_ISSUE
  /// Корректировка в плюс (инвентаризация, оприходование)
  ADJUSTMENT_PLUS
  /// Корректировка в минус (недостача и т.п.)
  ADJUSTMENT_MINUS
  /// Списание брака
  DEFECT_WRITE_OFF
  /// Возврат на склад (от клиента / отмена списания)
  RETURN_IN
}

/// Склад (логистическая единица учёта)
model Warehouse {
  id            String   @id @default(cuid())
  name          String
  /// Тип / назначение склада (свободный текст: основной, магазин и т.д.)
  warehouseType String?
  isDefault     Boolean  @default(false)
  isActive      Boolean  @default(true)
  notes         String?
  createdAt     DateTime @default(now())

  items     InventoryItem[]
  balances  StockBalance[]
  movements StockMovement[]
}

/// Учётная позиция склада (SKU), привязана к одному складу.
model InventoryItem {
  id                    String    @id @default(cuid())
  warehouseId           String
  warehouse             Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  /// Внутренний артикул (в рамках склада; уникален вместе с warehouseId)
  sku                   String?
  name                  String
  /// Единица учёта: шт, упак, кг…
  unit                  String    @default("шт")
  /// Производитель
  manufacturer          String?
  /// Сколько единиц учёта в одной поставке/упаковке (для списания «поставками» в UI)
  unitsPerSupply        Float?
  /// Справочная цена за единицу учёта, ₽ (фактическая средняя — в остатке)
  referenceUnitPriceRub Float?
  notes                 String?
  isActive              Boolean   @default(true)
  sortOrder             Int       @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  balances  StockBalance[]
  movements StockMovement[]

  @@unique([warehouseId, sku])
  @@index([warehouseId])
  @@index([isActive, sortOrder])
  @@index([name])
}

/// Агрегат остатка по позиции и складу (обновляется только через движения)
model StockBalance {
  id                 String        @id @default(cuid())
  itemId             String
  item               InventoryItem @relation(fields: [itemId], references: [id], onDelete: Restrict)
  warehouseId        String
  warehouse          Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  quantityOnHand     Float         @default(0)
  /// Средневзвешенная закупочная цена за единицу, руб.
  averageUnitCostRub Float?
  updatedAt          DateTime      @updatedAt

  @@unique([itemId, warehouseId])
}

/// Журнал движений (источник правды для остатков и себестоимости)
model StockMovement {
  id                    String            @id @default(cuid())
  createdAt             DateTime          @default(now())
  kind                  StockMovementKind
  quantity              Float
  /// Себестоимость строки движения, руб. (приход: закупка; расход: списание по средней)
  totalCostRub          Float?
  note                  String?
  itemId                String
  item                  InventoryItem     @relation(fields: [itemId], references: [id], onDelete: Restrict)
  warehouseId           String
  warehouse             Warehouse         @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  orderId               String?
  order                 Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull)
  actorLabel            String            @default("Пользователь")
  idempotencyKey        String?           @unique
  /// Для SALE_ISSUE: после «вернуть на склад» помечается время (строка в журнале зачёркнута)
  returnedToWarehouseAt DateTime?

  @@index([itemId, createdAt])
  @@index([warehouseId, createdAt])
  @@index([orderId])
}

enum ConstructionCategory {
  FIXED
  CONNECTING
  BRIDGE
  MISSING_TEETH
  ARCH
  /// Позиция из прайс-листа (без привязки к зубам / дуге)
  PRICE_LIST
}

/// Версия калькулятора себестоимости (прайс по дате, набор колонок и формул).
model CostingVersion {
  id                    String                 @id @default(cuid())
  title                 String
  /// Дата начала действия версии (для отчётов и сопоставления с нарядами).
  effectiveFrom         DateTime?
  archived              Boolean                @default(false)
  /// Постоянные расходы (аренда, оклады, коммуналка и т.д.) в ₽ за тот же период, что и сумма выручки по таблице.
  monthlyFixedCostsRub  Float                  @default(0)
  /// Пояснение к периоду постоянных расходов (например «за месяц», «за квартал»).
  fixedCostsPeriodNote  String?
  /// Ожидаемое число работ в месяц (для деления Σ постоянных на нагрузку).
  expectedWorksPerMonth Float?
  columns               CostingColumn[]
  lines                 CostingLine[]
  sharedPools           CostingSharedPool[]
  fixedCostItems        CostingFixedCostItem[]
  profiles              CostingClientProfile[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@index([archived, effectiveFrom])
}

/// Пункт постоянных расходов версии (аренда, оклады…); сумма строк = monthlyFixedCostsRub.
model CostingFixedCostItem {
  id        String         @id @default(cuid())
  versionId String
  version   CostingVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  label     String
  amountRub Float          @default(0)
  sortOrder Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([versionId, sortOrder])
}

/// Общая статья затрат на версию (аренда, лицензия CAD и т.п.): сумма и доли по строкам позиций.
model CostingSharedPool {
  id        String                 @id @default(cuid())
  versionId String
  version   CostingVersion         @relation(fields: [versionId], references: [id], onDelete: Cascade)
  /// Ключ для формул: переменная sh_<key>, латиница и подчёркивание.
  key       String
  label     String
  /// Ориентир «всего по статье» (₽); сумма долей по строкам может отличаться — контроль в таблице.
  totalRub  Float                  @default(0)
  sortOrder Int                    @default(0)
  shares    CostingLinePoolShare[]

  @@unique([versionId, key])
  @@index([versionId, sortOrder])
}

/// Сколько рублей этой общей статьи относится на конкретную строку расчёта (остальные строки — 0).
model CostingLinePoolShare {
  lineId   String
  poolId   String
  pool     CostingSharedPool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  line     CostingLine       @relation(fields: [lineId], references: [id], onDelete: Cascade)
  shareRub Float             @default(0)

  @@id([lineId, poolId])
  @@index([poolId])
}

/// Колонка: ввод числа или вычисление по формуле (ключи других колонок как переменные).
enum CostingColumnKind {
  INPUT
  COMPUTED
}

model CostingColumn {
  id        String            @id @default(cuid())
  versionId String
  version   CostingVersion    @relation(fields: [versionId], references: [id], onDelete: Cascade)
  /// Латиница, цифры и подчёркивание — для формул.
  key       String
  label     String
  kind      CostingColumnKind
  /// Для COMPUTED: выражение expr-eval (переменные = key колонок, функция sum(...)).
  formula   String?
  sortOrder Int               @default(0)
  hint      String?

  @@unique([versionId, key])
  @@index([versionId, sortOrder])
}

/// Строка расчёта в версии: привязка к позиции прайса и значения входов по умолчанию.
model CostingLine {
  id              String                 @id @default(cuid())
  versionId       String
  version         CostingVersion         @relation(fields: [versionId], references: [id], onDelete: Cascade)
  priceListItemId String?
  priceListItem   PriceListItem?         @relation(fields: [priceListItemId], references: [id], onDelete: SetNull)
  /// Объект { columnKey: number } для INPUT-колонок.
  inputsJson      Json                   @default("{}")
  note            String?
  poolShares      CostingLinePoolShare[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([versionId])
  @@index([priceListItemId])
}

/// Сценарий «индивидуально под клиента»: скидка от номинала прайса при просчёте.
model CostingClientProfile {
  id                  String         @id @default(cuid())
  versionId           String
  version             CostingVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  clinicId            String?
  clinic              Clinic?        @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  name                String
  /// Скидка от поля «цена клиенту», % (10 = продаём на 10% ниже).
  listDiscountPercent Float          @default(0)
  note                String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([versionId])
  @@index([clinicId])
}

/// Каталог прайса (можно несколько: основной, архив, отдельная ветка).
model PriceList {
  id        String   @id @default(cuid())
  name      String
  sortOrder Int      @default(0)
  items     PriceListItem[]
  /// Наряды и формы подставляют позиции из «активного» каталога (см. PriceListWorkspaceSettings).
  activeForWorkspace PriceListWorkspaceSettings?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder, name])
}

/// Одна запись на приложение: какой каталог прайса использовать в нарядах по умолчанию.
model PriceListWorkspaceSettings {
  id                String    @id @default("default")
  activePriceListId String    @unique
  activePriceList   PriceList @relation(fields: [activePriceListId], references: [id], onDelete: Restrict)
  updatedAt         DateTime  @updatedAt
}

/// Позиция прайс-листа лаборатории (код, цена, срок, описание)
model PriceListItem {
  id              String    @id @default(cuid())
  priceListId     String
  priceList       PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  /// Код в прайсе, напр. "1001" (уникален в пределах каталога)
  code            String
  name            String
  /// Раздел верхнего уровня из Excel, напр. «1. ПОДГОТОВКА…»
  sectionTitle    String?
  /// Подраздел, напр. «1.1 Сплинты»
  subsectionTitle String?
  /// Цена в рублях
  priceRub        Int
  /// Срок в рабочих днях (как в Excel)
  leadWorkingDays Int?
  description     String?
  isActive        Boolean   @default(true)
  sortOrder       Int       @default(0)
  clinicOverrides ClinicPriceOverride[]
  constructions   OrderConstruction[]
  costingLines    CostingLine[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([priceListId, code])
  @@index([priceListId, isActive, sortOrder])
}

/// Индивидуальная цена позиции прайса для клиники.
model ClinicPriceOverride {
  clinicId       String
  priceListItemId String
  clinic         Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  priceListItem  PriceListItem @relation(fields: [priceListItemId], references: [id], onDelete: Cascade)
  /// Цена для этой клиники (руб), если запись существует — переопределяет базовую цену.
  priceRub       Int
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@id([clinicId, priceListItemId])
  @@index([priceListItemId])
}

enum JawArch {
  UPPER
  LOWER
  BOTH
}

/// Одна позиция в заказе: конструкция, мост, работа на челюсть и т.п.
model OrderConstruction {
  id                 String               @id @default(cuid())
  orderId            String
  order              Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  category           ConstructionCategory
  constructionTypeId String?
  constructionType   ConstructionType?    @relation(fields: [constructionTypeId], references: [id])
  priceListItemId    String?
  priceListItem      PriceListItem?       @relation(fields: [priceListItemId], references: [id])
  materialId         String?
  material           Material?            @relation(fields: [materialId], references: [id])
  shade              String?

  /// FDI взрослый (11–48) или молочный (51–85): массив строк, напр. ["14","15","16"]
  teethFdi Json?

  /// Мост: границы по FDI
  bridgeFromFdi String?
  bridgeToFdi   String?

  /// Сплинт, элайнер, аппарат — верх / низ / обе
  arch JawArch?

  /// Количество по позиции (для финансов / сверки)
  quantity  Int    @default(1)
  /// Цена за единицу, руб. (null — не задана, в суммах считается как 0)
  unitPrice Float?
  /// Скидка на позицию, % (0–100) — с цены за ед.×кол-во; до общей скидки на наряд
  lineDiscountPercent            Float   @default(0)

  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([orderId])
}
