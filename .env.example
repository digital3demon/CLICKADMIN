DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dental_lab_crm?schema=public"
# Источник для разового ETL при переходе с SQLite на PostgreSQL:
# LEGACY_SQLITE_URL="file:./prisma/dev.db"
# Split-режим БД отключён (single PostgreSQL DB):
# DB_SPLIT_ENABLED=0
# Для deploy PostgreSQL используйте npm run db:migrate:deploy
# Не запускайте вручную просто `npx prisma migrate deploy` без @версии — подтянется Prisma 7+ (P1012, несовместимость schema).
# Если колонка diskRelPath уже появилась, а миграция в журнале не отмечена:
# npm run db:migrate:resolve:attachment-disk
# Каталог для файлов вложений нарядов (по умолчанию ./data/order-attachments от cwd)
# ORDER_ATTACHMENT_STORAGE_DIR=
# Отдельный SQLite для демо (не совпадать с DATABASE_URL). По умолчанию в коде: file:./prisma/demo.db
# DEMO_DATABASE_URL=file:./prisma/demo.db
# Если на сервере нет npx в PATH, демо вызывает Prisma через node …/prisma/build/index.js из node_modules.
# Если пакет prisma не попал в выкладку — укажите абсолютный путь к index.js: PRISMA_CLI_JS=/path/to/node_modules/prisma/build/index.js
# PRISMA_CLI_JS=
# 0 / false / no — не пересоздавать демо-БД при каждом входе в демо и при выходе; начальный сид только если демо ещё пустое
# DEMO_RESEED_ON_START=0

# --- Вход и пользователи ---
# Минимум 16 символов; в production без этого приложение не стартует защищённые маршруты
AUTH_SECRET="local-dev-only-replace-for-production-min-16-chars"

# Письмо с кодом приглашения (справочник пользователей). Без VPN в РФ удобнее SMTP (Яндекс, Mail.ru, корпоративный relay).
# EMAIL_FROM обязателен для любого способа: "Ваша лаборатория <noreply@ваш-домен.ru>"
# Вариант A — одна строка (nodemailer URL): smtps://user:pass@smtp.yandex.ru:465
# SMTP_URL=
# Вариант B — отдельные поля (порт по умолчанию 587; для 465 задайте SMTP_SECURE=1)
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=ваш@yandex.ru
# SMTP_PASS=пароль_приложения
# Вариант C — Unisender Go (Transactional API, ключ из кабинета «Отправить тестовое» / раздел API)
# EMAIL_FROM=noreply@ваш-подтверждённый-домен.ru
# Опционально имя отправителя в письме (иначе «КликАдмин»)
# EMAIL_FROM_NAME=КликАдмин
# UNISENDER_GO_API_KEY=
# Только если другой endpoint дата-центра (ошибка «User not found» / код 114 — см. документацию Unisender)
# UNISENDER_GO_SEND_URL=https://goapi.unisender.ru/ru/transactional/api/v1/email/send.json
# Вариант D — Resend (https://resend.com), если доступен
# RESEND_API_KEY=re_...
# Публичный URL сайта (письма, ссылки из getSiteOrigin и т.д.). На Vercel можно не задавать — возьмётся VERCEL_URL
# CRM_PUBLIC_BASE_URL=https://crm.example.com
# Одна лаборатория в БД (Tenant.slug): принудительно этот slug при входе с любого Host (иначе slug = первая метка хоста, напр. lab из lab.example.com)
# CRM_DEFAULT_TENANT_SLUG=default
# Автоактивация tenant DB в процессе deploy (scripts/prisma-migrate-deploy.cjs):
# 1 — после migrate/generate скрипт сам выполнит tenant:provision:db с ACTIVATE=1
# TENANT_DB_AUTO_ACTIVATE=1
# URL актуальной отдельной БД вашего tenant:
# TENANT_DATABASE_URL=postgresql://USER:PASS@HOST:5432/TENANT_DB
# Явный slug (если пусто, возьмется CRM_DEFAULT_TENANT_SLUG):
# TENANT_SLUG=default
# Необязательно: имя tenant (для upsert записи Tenant)
# TENANT_NAME=default
# Вход через Telegram Login Widget: https://core.telegram.org/widgets/login
# 1) @BotFather → /newbot → токен в TELEGRAM_BOT_TOKEN (только сервер, не в git)
# 2) @BotFather → /setdomain → домен сайта (например example.com без https)
# 3) Имя бота без @ — в NEXT_PUBLIC_TELEGRAM_BOT_NAME (видно в виджете на клиенте)
# TELEGRAM_BOT_TOKEN=123456:ABC...
# NEXT_PUBLIC_TELEGRAM_BOT_NAME=YourLabCrmBot
# Входящий webhook бота (привязка через чат): HTTPS …/api/telegram/webhook
# Если задан TELEGRAM_WEBHOOK_SECRET, при setWebhook укажите тот же secret_token (иначе Telegram получит 403 и бот не ответит).
# TELEGRAM_WEBHOOK_SECRET=случайная_длинная_строка
# Если setWebhook ругается на DNS: параметр ip_address (IP из A-записи домена) — scripts/telegram-webhook-tunnel.md
# Только для отладки «как portable»: одна станция без входа (не используйте на общем сервере)
# NEXT_PUBLIC_CRM_SINGLE_USER=1
# Виджет солнце/луна/погода в сайдбаре (по умолчанию выключен): раскомментируйте, чтобы включить
# NEXT_PUBLIC_CRM_WORKDAY_SKY=1
# Опционально: Resend для будущих писем из CRM (приглашения — код вручную, без Resend)
# https://resend.com/docs/send-with-nextjs
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com
# Опционально: при `npm run prisma db seed` создать/обновить владельца (пароль не короче 8)
# SEED_OWNER_EMAIL=owner@example.com
# SEED_OWNER_PASSWORD=
# SEED_OWNER_DISPLAY_NAME=Владелец

# --- Логи и мониторинг ---
# LOG_LEVEL=debug|info|warn|error
# LOG_PRETTY=0 — отключить pino-pretty в dev
# METRICS_SECRET=длинная_случайная_строка — доступ к GET /api/metrics (заголовок x-metrics-key)
# RATE_LIMIT_DISABLED=1 — отключить лимит запросов к /api (только для отладки)
# RATE_LIMIT_MAX_PER_WINDOW=240 — запросов с одного IP за окно (по умолчанию 60 с)

# --- Kaiten (см. документацию API: https://kshvakov.github.io/kaiten-api/) ---
# KAITEN_API_BASE_URL по умолчанию в коде: https://clicklab.kaiten.ru/api/v1
# Кэш ответа GET /api/orders/…/kaiten на сервере (сек), 0 = без кэша; по умолчанию 12
# KAITEN_SNAPSHOT_CACHE_SEC=12
# Пауза между исходящими запросами к Kaiten (мс), очередь на сервере — меньше 429; по умолчанию 90
# KAITEN_REQUEST_SPACING_MS=90
# Интервал опроса колонки в шапке наряда и фона списка заказов (мс): 1500–120000, по умолчанию 2500
# NEXT_PUBLIC_KAITEN_HEADER_POLL_MS=2500
# Интервал подтягивания нарядов на канбан (мс): 2000–120000, по умолчанию 5000
# NEXT_PUBLIC_KANBAN_LINKED_PULL_MS=5000
# Опрос «Корректировки» на наряде (мс), 1500–30000; по умолчанию 3500. При каждом запросе сервер подтягивает комментарии из Kaiten.
# NEXT_PUBLIC_ORDER_CHAT_CORRECTIONS_POLL_MS=3500
# Опрос глобальных уведомлений «корректировка по наряду…» (мс), 2500–30000, по умолчанию 4000
# NEXT_PUBLIC_ORDER_CORRECTION_TOAST_POLL_MS=4000
KAITEN_API_TOKEN=
KAITEN_API_BASE_URL=https://clicklab.kaiten.ru/api/v1

# ID типов карточек: GET /api/v1/card-types
KAITEN_TYPE_PERMANENT_ID=
KAITEN_TYPE_TEMPORARY_ID=
KAITEN_TYPE_SPLINT_ID=
# Базовый тип «Card» в Kaiten (часто id=1); для CRM-варианта CARD
KAITEN_TYPE_CARD_ID=1

# Доп. типы карточек (числовой id из GET /api/v1/card-types), если отличаются от дефолта «1»
# KAITEN_MAP_ORTOAPPARATY_ID=
# KAITEN_MAP_ORTOAPPARATY_HIRURGIYA_ID=

# Доска и колонка «к исполнению» (часто первая колонка, у вас «Очередь»).
# В URL вида https://…kaiten.ru/space/511557/boards число 511557 — это id ПРОСТРАНСТВА (space), не доски.
# Вариант A: KAITEN_*_BOARD_ID = числовой id доски из ответа API GET /api/v1/spaces/{space_id}/boards → boards[0].id
# Вариант B: задать только KAITEN_*_SPACE_ID = это число из URL — CRM сама запросит первую доску пространства.
# GET /api/v1/boards/{board_id}/columns — id колонки старта (часто «К исполнению» / «Очередь»)
# Пример clicklab: ортопедия board_id=1202679, колонка «К исполнению»=4192800; ортодонтия 1202674 / 4192775
# Полный список column_id / lane_id для ваших досок: npm run kaiten:dump-boards (скрипт дергает API).
# Пример справки (clicklab, 2026): доска 1202679 — колонки 5371392 НА СКАН, 4192800 К исполнению,
#   4192801 Согласование, 4192802 Производство, 4192803 Сборка, 4336082 Обработка, 4192804 Мануал,
#   4192806 На проверку, 4192805 Сдана админам; lane 1476372 «Стандартный срок и срочные».
# Доска 1202674 — 5371393, 4192775, 4192778, 4192776, 4192784, 4336076, 4192786, 4192788, 4192777;
#   lane 1476365 «Стандартный срок».
KAITEN_ORTHOPEDICS_BOARD_ID=
# KAITEN_ORTHOPEDICS_SPACE_ID=511557
KAITEN_ORTHOPEDICS_COLUMN_TO_EXECUTION_ID=
KAITEN_ORTHODONTICS_BOARD_ID=
# KAITEN_ORTHODONTICS_SPACE_ID=511567
KAITEN_ORTHODONTICS_COLUMN_TO_EXECUTION_ID=

# Пространство «ТЕСТ» в CRM (lane TEST): если не задано — берутся доска/колонка ортопедии
# KAITEN_TEST_BOARD_ID=
# KAITEN_TEST_SPACE_ID=760817
# KAITEN_TEST_COLUMN_TO_EXECUTION_ID=
# KAITEN_TEST_LANE_ID=

# Необязательно: полоса (lane) для новых карточек — GET /api/v1/boards/{board_id}/lanes
# Если не задано, CRM берёт первую lane (лишний запрос к API при каждом создании карточки).
# KAITEN_ORTHOPEDICS_LANE_ID=1476372
# KAITEN_ORTHODONTICS_LANE_ID=1476365

# Мультитенант / SaaS, портал, биллинг — в отдельной папке `dental-crm-saas/` (см. README-SAAS.txt там). Здесь только лаб-CRM.
