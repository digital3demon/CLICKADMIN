{
  "name": "dental-lab-crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --reporter=dot",
    "typecheck": "tsc --noEmit",
    "dev": "next dev --turbo",
    "dev:webpack": "next dev",
    "build": "node scripts/prisma-migrate-deploy.cjs && next build && node scripts/copy-standalone-assets.cjs && node scripts/verify-standalone-after-build.cjs",
    "bootstrap:saas": "node scripts/bootstrap-dental-crm-saas.cjs",
    "start": "node server.js",
    "start:next": "next start",
    "db:generate": "prisma generate",
    "db:generate:clean": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prisma-clean-generate.ps1",
    "db:generate:clean:force": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prisma-clean-generate.ps1 -KillAllNode",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "node scripts/prisma-migrate-deploy.cjs",
    "db:migrate:resolve:attachment-disk": "prisma migrate resolve --applied 20260420190000_order_attachment_disk_rel_path",
    "db:backup": "node --env-file=.env scripts/db-backup.cjs",
    "db:migrate:sqlite-to-pg:dry-run": "node --env-file=.env scripts/migrate-sqlite-to-postgres.cjs --dry-run",
    "db:migrate:sqlite-to-pg": "node --env-file=.env scripts/migrate-sqlite-to-postgres.cjs",
    "db:migrate:sqlite-to-pg:force": "node --env-file=.env scripts/migrate-sqlite-to-postgres.cjs --force",
    "db:validate:sqlite-to-pg": "node --env-file=.env scripts/validate-postgres-migration.cjs",
    "db:push": "prisma db push",
    "db:fix-user-telegram-phone": "node --env-file=.env scripts/ensure-user-telegram-phone-sqlite.cjs",
    "db:sync": "prisma db push",
    "db:push:reset": "prisma db push --force-reset --accept-data-loss",
    "db:seed": "prisma db seed",
    "owner:set-password": "node --env-file=.env scripts/set-owner-password.cjs",
    "db:reset": "node --env-file=.env scripts/reset-and-import.cjs --no-import",
    "db:reset:import": "node --env-file=.env scripts/reset-and-import.cjs",
    "db:orders:clear": "node --env-file=.env scripts/clear-orders-keep-clinics-doctors.cjs",
    "db:contractors:export": "node --env-file=.env scripts/contractors-backup-restore.cjs export",
    "db:contractors:import": "node --env-file=.env scripts/contractors-backup-restore.cjs import",
    "db:price:export": "node --env-file=.env scripts/price-backup-restore.cjs export",
    "db:price:import": "node --env-file=.env scripts/price-backup-restore.cjs import",
    "db:studio": "prisma studio",
    "import:clinics": "node --env-file=.env scripts/import-clinics-xlsx.cjs",
    "import:clinics:1": "node --env-file=.env scripts/import-clinics-xlsx.cjs data/imports/1.xlsx",
    "sync:clinics:billing": "node --env-file=.env scripts/import-clinics-xlsx.cjs data/imports/1.xlsx --billing-only",
    "sync:clinics:excel": "node --env-file=.env scripts/import-clinics-xlsx.cjs data/imports/1.xlsx --sync-clinic-excel",
    "import:doctors": "node --env-file=.env scripts/import-doctors-xlsx.cjs",
    "repair:doctor-import-merge": "node --env-file=.env scripts/repair-doctor-import-merged-clinics.cjs",
    "repair:swapped-clinic-fields": "node --env-file=.env scripts/repair-swapped-clinic-fields.cjs",
    "db:doctors:reimport": "node --env-file=.env scripts/clear-doctors-and-reimport.cjs",
    "db:doctors:prune-sparse": "node --env-file=.env scripts/prune-sparse-doctors.cjs",
    "import:clinics-pdf": "node --env-file=.env scripts/import-clinics-pdf.cjs",
    "db:clinics:cleanup": "node --env-file=.env scripts/cleanup-clinics.cjs",
    "import:price": "node --env-file=.env scripts/import-price-xlsx.cjs",
    "package:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-standalone-windows.ps1",
    "package:windows:empty": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-standalone-windows.ps1 -SkipBundledDatabase",
    "package:server-tar": "bash scripts/package-server-archive.sh",
    "package:server-tar:ps1": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-server-archive.ps1",
    "package:server": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-server-archive.ps1",
    "kaiten:dump-boards": "node --env-file=.env scripts/kaiten-dump-board-columns.cjs",
    "contract:test": "node --env-file=.env scripts/generate-test-contract.cjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource/noto-sans": "^5.2.10",
    "@napi-rs/canvas": "^0.1.99",
    "@prisma/client": "^6.6.0",
    "@react-pdf/renderer": "^4.4.0",
    "bcryptjs": "^3.0.3",
    "exceljs": "^4.4.0",
    "expr-eval": "^2.0.2",
    "framer-motion": "^11.18.2",
    "jose": "^6.2.2",
    "next": "^15.2.4",
    "nodemailer": "^6.10.0",
    "pdf-parse": "^2.4.5",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "@tailwindcss/postcss": "^4.1.3",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.3",
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/qrcode": "^1.5.6",
    "@types/nodemailer": "^6.4.17",
    "typescript": "^5.8.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "jszip": "^3.10.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.6.0",
    "vitest": "^3.2.4"
  },
  "optionalDependencies": {
    "@napi-rs/canvas-linux-x64-gnu": "^0.1.99"
  },
  "engines": {
    "node": ">=20.16.0"
  }
}
