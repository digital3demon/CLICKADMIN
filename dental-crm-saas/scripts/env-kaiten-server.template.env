# =============================================================================
# Kaiten — скопируйте этот блок в /var/www/dental-lab-crm/.env (и в .next/standalone/.env, если PM2 стартует оттуда).
# Значения возьмите из вашего РАБОЧЕГО локального .env (тот же инстанс Kaiten).
# Токен и id не коммитьте в git.
# =============================================================================

# Обязательно: API-токен из настроек Kaiten (или скопируйте строку из локального .env целиком).
KAITEN_API_TOKEN="ВСТАВЬТЕ_ТОКЕН"

# Обычно так же, как локально (если не свой хост Kaiten — не меняйте).
KAITEN_API_BASE_URL=https://clicklab.kaiten.ru/api/v1

# Типы карточек (числа из GET …/card-types) — скопируйте с локали или оставьте как у вас в dev.
KAITEN_TYPE_CARD_ID=1
KAITEN_TYPE_PERMANENT_ID=
KAITEN_TYPE_TEMPORARY_ID=
KAITEN_TYPE_SPLINT_ID=

# --- Ортопедия: задайте ЛИБО BOARD_ID, ЛИБО SPACE_ID (не оба обязательны; вторая строка закомментирована, если используете board).
# Доска и колонка «к исполнению» — id из API или из npm run kaiten:dump-boards
KAITEN_ORTHOPEDICS_BOARD_ID=
# KAITEN_ORTHOPEDICS_SPACE_ID=
KAITEN_ORTHOPEDICS_COLUMN_TO_EXECUTION_ID=
# KAITEN_ORTHOPEDICS_LANE_ID=

# --- Ортодонтия (то же правило: board или space)
KAITEN_ORTHODONTICS_BOARD_ID=
# KAITEN_ORTHODONTICS_SPACE_ID=
KAITEN_ORTHODONTICS_COLUMN_TO_EXECUTION_ID=
# KAITEN_ORTHODONTICS_LANE_ID=

# --- Тестовая дорожка (необязательно)
# KAITEN_TEST_BOARD_ID=
# KAITEN_TEST_SPACE_ID=
# KAITEN_TEST_COLUMN_TO_EXECUTION_ID=
# KAITEN_TEST_LANE_ID=

# Опционально (как в .env.example)
# KAITEN_SNAPSHOT_CACHE_SEC=40
# NEXT_PUBLIC_KAITEN_HEADER_POLL_MS=12000
