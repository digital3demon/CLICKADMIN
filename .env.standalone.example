# Скопируйте в .env в корне переносимой папки (рядом с server.js).
# Путь относителен к каталогу prisma\ (рядом со schema.prisma) — файл: prisma\dev.db
# Не используйте file:./prisma/dev.db — получится prisma\prisma\dev.db и сервер увидит пустую БД.

DATABASE_URL="file:./dev.db"

# При сборке npm run package:windows в папку копируется prisma\dev.db из проекта (если есть)
# и создаётся prisma\.PORTABLE_FULL_DB — тогда Запуск.bat не делает db push и seed.

# Переносимая сборка (npm run package:windows) — один пользователь, без входа и
# без раздела «Пользователи». Флаг NEXT_PUBLIC_CRM_SINGLE_USER вшивается при сборке;
# в этом .env указывать его не нужно.

# Опционально — Kaiten (как в основном .env.example)
# KAITEN_API_TOKEN=
